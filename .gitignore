__pycache__/
*.pyc

# Node.js
node_modules/
npm-debug.log*
yarn-error.log*

# Production build
dist/
dist.tar.gz

# Environment variables (API Keys)
.env

# OS generated files
.DS_Store

# SQLite Database files
*.db
*.db-journal
*.db-wal